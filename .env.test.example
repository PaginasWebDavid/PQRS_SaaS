# Configuracion de la base de datos de PRUEBAS.
#
# Copia este archivo a `.env.test` (ignorado por Git) y ajusta los valores.
# `npm test` valida estas variables ANTES de crear cualquier cliente Prisma y
# aborta si algo es inseguro. Todos los valores de aqui son FICTICIOS: nunca
# pongas credenciales reales en `.env.test.example`.
#
# Prioridad de resolucion: variables del sistema/CI > .env.test > .env

# --- Obligatorias -----------------------------------------------------------

# Base de datos de PRUEBAS dedicada (conexion normal / pooler). DEBE apuntar a un
# destino distinto de DATABASE_URL. Su nombre debe ser de pruebas: exacto
# (test, tests, qa, ci, sandbox, e2e) o con prefijo/sufijo delimitado
# (p. ej. pqrs_test, test_pqrs). Ver TEST_DATABASE_ALLOWED_TARGETS para excepciones.
TEST_DATABASE_URL="postgresql://test_user:test_password@localhost:5432/pqrs_test"

# Confirmacion explicita de que autorizas que las pruebas CREEN y BORREN datos en
# esa base. Debe ser exactamente "true"; cualquier otro valor bloquea la suite.
ALLOW_TEST_DATABASE_MUTATION=true

# --- Para comandos Prisma de pruebas (test:db:deploy / test:db:push) ---------

# Conexion DIRECTA (no pooler) de la base de PRUEBAS, usada por Prisma para
# migraciones. Obligatoria para `npm run test:db:deploy` / `test:db:push`, salvo
# que autorices el fallback de abajo.
TEST_DIRECT_URL="postgresql://test_user:test_password@localhost:5432/pqrs_test"

# (Opcional) Permite usar TEST_DATABASE_URL como DIRECT_URL cuando no defines
# TEST_DIRECT_URL. Solo si sabes que tu TEST_DATABASE_URL sirve como conexion directa.
# ALLOW_TEST_DIRECT_URL_FALLBACK=true

# --- Opcionales (defensa secundaria de nombre) ------------------------------

# Allowlist explicita de destinos de pruebas, separada por comas. Acepta
# "host/base" o solo "base". Si se define, reemplaza la heuristica de nombre.
# TEST_DATABASE_ALLOWED_TARGETS="localhost/pqrs_qa,db.miproyecto.supabase.co/postgres"

# Bypass DELIBERADO de la defensa secundaria de nombre. No es configuracion
# normal: usala solo si tu base de pruebas no encaja en el patron y estas seguro
# de que NO es la base normal ni produccion.
# TEST_DATABASE_ALLOW_ANY_NAME=true
