generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  status    TenantStatus @default(ACTIVE)
  units     Int          @default(0)
  city      String?
  address   String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  users     User[]
  pqrs      Pqrs[]
  fotos     PqrsFoto[]
  historial HistorialPqrs[]

  @@index([slug])
  @@index([status])
}

enum TenantStatus {
  TRIAL
  ACTIVE
  GRACE_PERIOD
  SUSPENDED
  CANCELLED
}

model User {
  id                    String     @id @default(cuid())
  email                 String     @unique
  password              String
  name                  String
  role                  Role       @default(RESIDENTE)
  tenantId              String?
  tenant                Tenant?    @relation(fields: [tenantId], references: [id])
  bloque                Int?
  apto                  Int?
  haCorregidoUbicacion  Boolean    @default(false)
  emailVerified         DateTime?
  image                 String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  pqrsCreated           Pqrs[]     @relation("CreatedBy")
  pqrsManaged           Pqrs[]     @relation("ManagedBy")
  auditLogs             AuditLog[] @relation("AuditActor")
  sessions              Session[]
  accounts              Account[]

  @@index([tenantId])
  @@index([role])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  ASISTENTE
  CONSEJO
  RESIDENTE
}

model AuditLog {
  id          String      @id @default(cuid())
  actorUserId String?
  actor       User?       @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  action      AuditAction
  targetType  String?
  targetId    String?
  metadata    Json?
  createdAt   DateTime    @default(now())

  @@index([actorUserId])
  @@index([action])
  @@index([createdAt])
}

enum AuditAction {
  TENANT_CREATED
  TENANT_SUSPENDED
  TENANT_REACTIVATED
  PLATFORM_SETTING_CHANGED
  PRICING_RULE_CHANGED
}

model Pqrs {
  id                            String          @id @default(cuid())
  numero                        Int             @unique @default(autoincrement())
  tenantId                      String
  tenant                        Tenant          @relation(fields: [tenantId], references: [id])
  medio                         Medio           @default(PLATAFORMA_WEB)
  fechaRecibido                 DateTime
  mes                           String
  bloque                        Int
  apto                          Int
  nombreResidente               String
  tipoPqrs                      TipoPqrs?
  asunto                        String?
  subAsunto                     String?
  descripcion                   String          @db.Text
  numeroRadicacion              String?         @unique

  // Gestion por asistente/admin
  fechaPrimerContacto           DateTime?
  tiempoRespuestaPrimerContacto Int?
  notaPrimerContacto            String?         @db.Text
  accionTomada                  String?         @db.Text
  estado                        Estado          @default(EN_ESPERA)
  evidenciaCierre               String?         @db.Text
  evidenciaArchivoData          String?         @db.Text
  evidenciaArchivoUrl           String?         @db.Text
  evidenciaArchivoPath          String?
  evidenciaArchivoNombre        String?
  evidenciaArchivoTipo          String?
  evidenciaArchivoSize          Int?
  fechaCierre                   DateTime?
  tiempoRespuestaCierre         Int?

  // Fases de gestion (solo admin, no visible para residente)
  faseActual                    Int?            // 1-5, null = sin fase asignada
  faseTipo                      String?         // "INSUMOS" (Fase II) o "PROVEEDOR" (Fase III)
  fase1Inicio                   DateTime?       // Inspeccion de Campo
  fase1Nota                     String?         @db.Text
  fase2Inicio                   DateTime?       // Adquisicion de insumos
  fase2Nota                     String?         @db.Text
  fase3Inicio                   DateTime?       // Firma contrato proveedor
  fase3Nota                     String?         @db.Text
  fase4Inicio                   DateTime?       // Ejecucion
  fase4Nota                     String?         @db.Text
  fase5Inicio                   DateTime?       // Terminado
  queSeHizoParaCerrar           String?         @db.Text  // Obligatorio si se cierra sin completar todas las fases

  // Metadata
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  creadoPor       User?     @relation("CreatedBy", fields: [creadoPorId], references: [id])
  creadoPorId     String?
  gestionadoPor   User?     @relation("ManagedBy", fields: [gestionadoPorId], references: [id])
  gestionadoPorId String?

  // Trazabilidad
  historial HistorialPqrs[]
  fotos     PqrsFoto[]

  @@index([tenantId])
  @@index([tenantId, estado])
  @@index([tenantId, fechaRecibido])
}

enum Medio {
  PLATAFORMA_WEB
}

enum TipoPqrs {
  PETICION
  QUEJA
  RECLAMO
  SUGERENCIA
}

enum Estado {
  EN_ESPERA
  EN_PROGRESO
  TERMINADO
}

model PqrsFoto {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  pqrsId      String
  pqrs        Pqrs     @relation(fields: [pqrsId], references: [id], onDelete: Cascade)
  data        String?  @db.Text
  url         String?  @db.Text
  storagePath String?
  nombre      String
  tipo        String
  size        Int?
  orden       Int
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([pqrsId])
}

model HistorialPqrs {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  pqrsId        String
  pqrs          Pqrs     @relation(fields: [pqrsId], references: [id], onDelete: Cascade)
  estadoAntes   Estado?
  estadoDespues Estado
  nota          String?
  creadoAt      DateTime @default(now())

  @@index([tenantId])
  @@index([pqrsId])
}

// NextAuth tables
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}