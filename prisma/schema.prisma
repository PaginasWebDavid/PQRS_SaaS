generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  status      TenantStatus @default(ACTIVE)
  units       Int          @default(0)
  city        String?
  address     String?
  cancelledAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  users         User[]
  pqrs          Pqrs[]
  fotos         PqrsFoto[]
  historial     HistorialPqrs[]
  subscription  Subscription?
  payments      Payment[]
  invitations   Invitation[]
  notifications Notification[]
  emailLogs     EmailLog[]
  auditLogs     AuditLog[]
  supportTickets SupportTicket[]

  @@index([slug])
  @@index([status])
}

enum TenantStatus {
  PENDING_PAYMENT
  TRIAL
  ACTIVE
  GRACE_PERIOD
  SUSPENDED
  CANCELLED
}

model User {
  id                    String     @id @default(cuid())
  email                 String     @unique
  password              String
  name                  String
  role                  Role       @default(RESIDENTE)
  tenantId              String?
  tenant                Tenant?    @relation(fields: [tenantId], references: [id])
  bloque                Int?
  apto                  Int?
  haCorregidoUbicacion  Boolean    @default(false)
  emailVerified         DateTime?
  image                 String?
  phone                 String?
  isActive              Boolean    @default(true)
  onboardingCompletedAt DateTime?
  notifyNewPqrsEmail    Boolean    @default(true)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  pqrsCreated           Pqrs[]     @relation("CreatedBy")
  pqrsManaged           Pqrs[]     @relation("ManagedBy")
  auditLogs             AuditLog[]        @relation("AuditActor")
  invitedInvitations    Invitation[]      @relation("InvitationInvitedBy")
  notifications         Notification[]
  updatedSettings       PlatformSetting[] @relation("PlatformSettingUpdatedBy")
  supportTicketsCreated   SupportTicket[] @relation("SupportTicketCreatedBy")
  supportTicketsResponded SupportTicket[] @relation("SupportTicketRespondedBy")
  sessions              Session[]
  accounts              Account[]

  @@index([tenantId])
  @@index([role])
  @@index([tenantId, role])
  @@index([tenantId, isActive])
  @@index([tenantId, bloque, apto])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  ASISTENTE
  CONSEJO
  RESIDENTE
}

model AuditLog {
  id           String      @id @default(cuid())
  tenantId     String?
  tenant       Tenant?     @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actorUserId  String?
  actor        User?       @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  action       AuditAction
  targetType   String?
  targetId     String?
  resourceType String?
  resourceId   String?
  origin       String?
  metadata     Json?
  createdAt    DateTime    @default(now())

  @@index([tenantId])
  @@index([actorUserId])
  @@index([action])
  @@index([createdAt])
  @@index([targetType, targetId])
  @@index([resourceType, resourceId])
}

enum AuditAction {
  TENANT_CREATED
  TENANT_SUSPENDED
  TENANT_REACTIVATED
  TENANT_CANCELLED
  TENANT_UPDATED
  TENANT_OVERDUE_RULES_APPLIED
  PLATFORM_SETTING_CHANGED
  PRICING_RULE_CHANGED
  SUBSCRIPTION_CREATED
  SUBSCRIPTION_RENEWED
  PAYMENT_SIMULATED
  MERCADO_PAGO_SUBSCRIPTION_CREATED
  MERCADO_PAGO_WEBHOOK_PROCESSED
  INVITATION_CREATED
  INVITATION_RESENT
  INVITATION_ACCEPTED
  INVITATION_CANCELLED
  INVITATION_EXPIRED
  NOTIFICATION_CREATED
  EMAIL_SENT
  EMAIL_FAILED
  PQRS_CREATED
  PQRS_UPDATED
  PQRS_CLOSED
  USER_UPDATED
  USER_DEACTIVATED
  USER_REACTIVATED
  ONBOARDING_COMPLETED
  PROFILE_UPDATED
  SUPPORT_TICKET_CREATED
  SUPPORT_TICKET_RESPONDED
  SUPPORT_TICKET_CLOSED
  REPORT_GENERATED
  REPORT_EXPORTED
  SUBSCRIPTION_AUTO_RENEW_DISABLED
  SUBSCRIPTION_AUTO_RENEW_ENABLED
  SUBSCRIPTION_PAYMENT_FAILED
}

enum SupportTicketStatus {
  ABIERTA
  RESPONDIDA
  CERRADA
}

enum SupportTicketCategory {
  TECNICO
  FACTURACION
  CUENTA
  OTRO
}

model SupportTicket {
  id                String                @id @default(cuid())
  tenantId          String
  tenant            Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdByUserId   String
  createdBy         User                  @relation("SupportTicketCreatedBy", fields: [createdByUserId], references: [id])
  subject           String
  message           String                @db.Text
  category          SupportTicketCategory @default(OTRO)
  status            SupportTicketStatus   @default(ABIERTA)
  response          String?               @db.Text
  respondedAt       DateTime?
  respondedByUserId String?
  respondedBy       User?                 @relation("SupportTicketRespondedBy", fields: [respondedByUserId], references: [id])
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([createdByUserId])
}

model PricingRule {
  id        String   @id @default(cuid())
  minUnits  Int
  maxUnits  Int?
  priceCents Int
  currency  String   @default("COP")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([minUnits, maxUnits])
}

model Subscription {
  id                 String             @id @default(cuid())
  tenantId           String             @unique
  tenant             Tenant             @relation(fields: [tenantId], references: [id])
  status             SubscriptionStatus @default(PENDING_PAYMENT)
  autoRenew          Boolean            @default(true)
  unitsSnapshot      Int
  priceCents         Int
  currency           String             @default("COP")
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  trialEndsAt        DateTime?
  graceEndsAt                 DateTime?
  mercadoPagoPreapprovalId    String?            @unique
  mercadoPagoInitPoint        String?            @db.Text
  mercadoPagoStatus           String?
  lastWebhookAt               DateTime?
  createdAt                   DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  payments           Payment[]

  @@index([tenantId, status])
  @@index([currentPeriodEnd])
}

enum SubscriptionStatus {
  PENDING_PAYMENT
  TRIAL
  ACTIVE
  GRACE_PERIOD
  SUSPENDED
  CANCELLED
}

model Payment {
  id                String          @id @default(cuid())
  tenantId          String
  tenant            Tenant          @relation(fields: [tenantId], references: [id])
  subscriptionId    String
  subscription      Subscription    @relation(fields: [subscriptionId], references: [id])
  amountCents       Int
  currency          String          @default("COP")
  status            PaymentStatus   @default(PENDING)
  provider          PaymentProvider @default(SIMULATED)
  dueDate           DateTime
  paidAt            DateTime?
  periodStart       DateTime
  periodEnd         DateTime
  externalReference    String?
  mercadoPagoPaymentId String?         @unique
  rawStatus            String?
  createdAt            DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([tenantId])
  @@index([subscriptionId])
  @@index([status, dueDate])
  @@index([tenantId, status, dueDate])
  @@index([createdAt])
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentProvider {
  SIMULATED
  MERCADO_PAGO
}

model Pqrs {
  id                            String          @id @default(cuid())
  numero                        Int             @unique @default(autoincrement())
  tenantId                      String
  tenant                        Tenant          @relation(fields: [tenantId], references: [id])
  medio                         Medio           @default(PLATAFORMA_WEB)
  fechaRecibido                 DateTime
  mes                           String
  bloque                        Int
  apto                          Int
  nombreResidente               String
  tipoPqrs                      TipoPqrs?
  titulo                        String?
  asunto                        String?
  subAsunto                     String?
  prioridad                     Prioridad       @default(MEDIA)
  descripcion                   String          @db.Text
  editadoPorResidente           Boolean         @default(false)
  numeroRadicacion              String?         @unique

  // Gestion por asistente/admin
  fechaPrimerContacto           DateTime?
  tiempoRespuestaPrimerContacto Int?
  notaPrimerContacto            String?         @db.Text
  accionTomada                  String?         @db.Text
  estado                        Estado          @default(EN_ESPERA)
  evidenciaCierre               String?         @db.Text
  evidenciaArchivoData          String?         @db.Text
  evidenciaArchivoUrl           String?         @db.Text
  evidenciaArchivoPath          String?
  evidenciaArchivoNombre        String?
  evidenciaArchivoTipo          String?
  evidenciaArchivoSize          Int?
  fechaCierre                   DateTime?
  tiempoRespuestaCierre         Int?

  // Fases de gestion (solo admin, no visible para residente)
  faseActual                    Int?            // 1-5, null = sin fase asignada
  faseTipo                      String?         // "INSUMOS" (Fase II) o "PROVEEDOR" (Fase III)
  fase1Inicio                   DateTime?       // Inspeccion de Campo
  fase1Nota                     String?         @db.Text
  fase2Inicio                   DateTime?       // Adquisicion de insumos
  fase2Nota                     String?         @db.Text
  fase3Inicio                   DateTime?       // Firma contrato proveedor
  fase3Nota                     String?         @db.Text
  fase4Inicio                   DateTime?       // Ejecucion
  fase4Nota                     String?         @db.Text
  fase5Inicio                   DateTime?       // Terminado
  queSeHizoParaCerrar           String?         @db.Text  // Obligatorio si se cierra sin completar todas las fases

  // Metadata
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  creadoPor       User?     @relation("CreatedBy", fields: [creadoPorId], references: [id])
  creadoPorId     String?
  gestionadoPor   User?     @relation("ManagedBy", fields: [gestionadoPorId], references: [id])
  gestionadoPorId String?

  // Trazabilidad
  historial HistorialPqrs[]
  fotos     PqrsFoto[]

  @@index([tenantId])
  @@index([tenantId, estado])
  @@index([tenantId, fechaRecibido])
  @@index([tenantId, numero])
  @@index([tenantId, mes])
  @@index([tenantId, asunto])
  @@index([tenantId, bloque, apto])
  @@index([tenantId, creadoPorId])
}

enum Medio {
  PLATAFORMA_WEB
}

enum TipoPqrs {
  PETICION
  QUEJA
  RECLAMO
  SUGERENCIA
}

enum Estado {
  EN_ESPERA
  EN_PROGRESO
  TERMINADO
}

enum Prioridad {
  ALTA
  MEDIA
  BAJA
}

model PqrsFoto {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  pqrsId      String
  pqrs        Pqrs     @relation(fields: [pqrsId], references: [id], onDelete: Cascade)
  data        String?  @db.Text
  url         String?  @db.Text
  storagePath String?
  nombre      String
  tipo        String
  size        Int?
  orden       Int
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([pqrsId])
  @@index([tenantId, createdAt])
}

model HistorialPqrs {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  pqrsId        String
  pqrs          Pqrs     @relation(fields: [pqrsId], references: [id], onDelete: Cascade)
  estadoAntes   Estado?
  estadoDespues Estado
  nota          String?
  creadoAt      DateTime @default(now())

  @@index([tenantId])
  @@index([pqrsId])
  @@index([tenantId, creadoAt])
  @@index([tenantId, pqrsId, creadoAt])
}


model Invitation {
  id          String           @id @default(cuid())
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email       String
  role        Role
  tokenHash   String           @unique
  status      InvitationStatus @default(PENDING)
  expiresAt   DateTime
  invitedById String?
  invitedBy   User?            @relation("InvitationInvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)
  acceptedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([tenantId])
  @@index([tenantId, email])
  @@index([tenantId, status])
  @@index([expiresAt])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

model Notification {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         String
  title        String
  message      String    @db.Text
  resourceType String?
  resourceId   String?
  readAt       DateTime?
  createdAt    DateTime  @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([tenantId, userId, readAt])
  @@index([resourceType, resourceId])
  @@index([createdAt])
}

model EmailLog {
  id                String         @id @default(cuid())
  tenantId          String?
  tenant            Tenant?        @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  recipient         String
  template          String
  provider          String         @default("RESEND")
  providerMessageId String?
  status            EmailLogStatus
  errorMessage      String?        @db.Text
  sentAt            DateTime?
  createdAt         DateTime       @default(now())

  @@index([tenantId])
  @@index([recipient])
  @@index([template])
  @@index([status])
  @@index([createdAt])
}

enum EmailLogStatus {
  SENT
  FAILED
  SKIPPED
}

model PlatformSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  isSecret    Boolean  @default(false)
  updatedById String?
  updatedBy   User?    @relation("PlatformSettingUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isSecret])
  @@index([updatedById])
}
// NextAuth tables
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}


