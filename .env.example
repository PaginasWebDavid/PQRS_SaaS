# Base de datos - Supabase PostgreSQL
# DATABASE_URL: usar Transaction Pooler en Vercel/serverless, puerto 6543.
# DIRECT_URL: usar Direct Connection para migraciones Prisma, puerto 5432.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# NextAuth / URL publica
# NEXTAUTH_SECRET: generar uno nuevo con `openssl rand -base64 32` o `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`.
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

# Usuario inicial de plataforma para `npm run db:seed`.
SUPER_ADMIN_EMAIL="superadmin@pqrs.local"
SUPER_ADMIN_PASSWORD="cambia-esta-clave"

# Supabase Storage
SUPABASE_URL="https://PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="pqrs-evidencias"

# Email - Resend
# En produccion usar un dominio verificado, por ejemplo: PQRS Services <notificaciones@tu-dominio.com>
RESEND_API_KEY=""
RESEND_FROM_EMAIL="PQRS Services <notificaciones@tu-dominio.com>"

# Mercado Pago
# Access token de la app de Mercado Pago. Usar TEST-... en pruebas y APP_USR-... en produccion.
MERCADO_PAGO_ACCESS_TOKEN=""
MERCADO_PAGO_TEST_PAYER_EMAIL=""
# Secret signature del webhook configurado en Mercado Pago. Requiere una URL publica.
MERCADO_PAGO_WEBHOOK_SECRET=""

# Vercel Cron
CRON_SECRET=""
NEXT_PUBLIC_LEGAL_NAME=""
NEXT_PUBLIC_LEGAL_NIT=""
NEXT_PUBLIC_LEGAL_ADDRESS=""
NEXT_PUBLIC_LEGAL_CITY="Bogota, Colombia"
NEXT_PUBLIC_LEGAL_SUPPORT_EMAIL="hola@pqrsservices.com"
NEXT_PUBLIC_LEGAL_PRIVACY_EMAIL="privacidad@pqrsservices.com"
NEXT_PUBLIC_LEGAL_EFFECTIVE_DATE=""
